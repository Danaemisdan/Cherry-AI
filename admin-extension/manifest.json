{
  "manifest_version": 3,
  "name": "Cherry AI License Admin",
  "version": "1.0.0",
  "description": "License server for Cherry AI - Admin Panel",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:*/*"
  ],
  "background": {
    "service_worker": "admin-service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Cherry AI Admin"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["admin-panel.html", "admin-panel.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
