{
  "name": "cherry-ai-platform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node start.mjs",
    "dev:web": "npm run dev -w @cherry/web",
    "dev:backend": "npm run dev -w @cherry/backend",
    "dev:agent": "npm run dev -w @cherry/agent",
    "dev:agent:profile": "node scripts/dev-agent-profile.mjs",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "package:release": "node scripts/package-release.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "javascript-obfuscator": "^5.4.2",
    "terser": "^5.46.2",
    "vite-plugin-javascript-obfuscator": "^3.1.0"
  }
}
